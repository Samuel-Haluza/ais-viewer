<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="600" prefWidth="600" spacing="0" styleClass="login-root" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sk.ukf.aisviewer.controller.LoginController">

    <!-- Header -->
    <VBox alignment="CENTER" spacing="8" styleClass="login-header">
        <padding><Insets bottom="20" top="30" /></padding>
        <Label styleClass="login-title" text="AIS Viewer" />
    </VBox>

    <!-- Login Card -->
    <VBox alignment="CENTER_LEFT" maxWidth="600" spacing="16" styleClass="login-card">
        <padding><Insets bottom="28" left="32" right="32" top="24" /></padding>

        <Label styleClass="login-card-title" text="Prihlásiť sa" />

        <VBox spacing="6">
            <Label styleClass="field-label" text="Používateľské meno" />
            <TextField fx:id="usernameField" promptText="login@ukf.sk alebo login" styleClass="login-field" />
        </VBox>

        <VBox spacing="6">
            <Label styleClass="field-label" text="Heslo" />
            <PasswordField fx:id="passwordField" promptText="Zadajte heslo" styleClass="login-field" />
        </VBox>

        <Button fx:id="loginButton" defaultButton="true" maxWidth="Infinity" onAction="#handleLogin" styleClass="login-button" text="Prihlásiť sa" />

        <Label fx:id="statusLabel" maxWidth="256" styleClass="error-label" visible="false" wrapText="true" />
    </VBox>

    <!-- Footer -->
    <VBox alignment="CENTER" prefHeight="17.0" prefWidth="159.0" spacing="4">
        <padding><Insets bottom="10" top="20" /></padding>
    </VBox>

</VBox>
